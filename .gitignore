# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# vite
/dist

# misc
.DS_Store
*.pem

# Playwright MCP page snapshots / console logs — capture secrets verbatim, never commit
.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!supabase/functions/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# supabase local
supabase/.temp/
supabase/functions/.env
.next/
